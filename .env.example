# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=datagen
POSTGRES_PASSWORD=datagen
POSTGRES_DB=datagen
DATABASE_URL=postgresql+asyncpg://datagen:datagen@postgres:5432/datagen

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET_NAME=synthetic-data
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL of the backend API (reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800   # 50 MB
MAX_UPLOAD_ROWS=100000
