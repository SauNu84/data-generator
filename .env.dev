# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://datagen:datagen@postgres:5432/datagen

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MinIO (S3-compatible dev storage) ─────────────────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=datagen-files

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800   # 50 MB
MAX_UPLOAD_ROWS=100000

# ── Job TTL ───────────────────────────────────────────────────────────────────
JOB_OUTPUT_TTL_SECONDS=86400  # 24h
